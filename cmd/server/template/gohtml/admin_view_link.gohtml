<!DOCTYPE html>

<html>

{{ template "head.gohtml" . }}

<body>
    {{ template "flash.gohtml" . }}

    <h2>List of files</h2>

    <div>
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Uploaded at</th>
                    <th>Size</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {{ range .Data.Files }}
                <tr>
                    <td><a href="{{ .DownloadLink }}">{{ .Name }}</a></td>
                    <td>{{ .UploadedAt }}</td>
                    <td>{{ .Size }}</td>
                    <td>
                        <form action="{{ .DeleteLink }}" method="post">
                            <input type="submit" value="Delete" />
                        </form>
                    </td>
                </tr>
                {{ end }}
            </tbody>
        </table>
    </div>
</body>

</html>