<!DOCTYPE html>

<html>

{{ template "head.gohtml" . }}

{{with .Data.Link}}
<body>
    <h1><a href="/">Send me the Data</a></h1>

    <h2>{{ .Name }}</h2>

    <div>
        <form action="{{ .EditLink }}" method="post">
            <div>
                <label for="link_name">Link name:</label>
                <input type="text" name="name" id="link_name" value="{{ .Name }}" required maxlength="255" />
            </div>
            <div>
                <input type="checkbox" name="user_downloadable" id="user_downloadable"
                    {{ if .UserDownloadable }}
                        checked
                    {{ end }}
                />
                <label for="user_downloadable">Users can download files</label>
            </div>
            <div>
                <input type="checkbox" name="upload_enabled" id="upload_enabled"
                    {{ if .UploadEnabled }}
                        checked
                    {{ end }}
                />
                <label for="upload_enabled">Users can upload files</label>
            </div>
            {{ template "file_size_picker.gohtml" .MaxFileSizeBytes }}
            <div>
                <input type="submit" value="Save" />
            </div>
        </form>
        <form action="{{ .ViewLink }}" method="get">
            <input type="submit" value="Cancel">
        </form>
    </div>
    <script src="/static/logarithmic_file_size_picker.js"></script>
</body>
{{end}}

</html>
